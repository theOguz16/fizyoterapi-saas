NODE_ENV=staging
PORT=5501
DATABASE_URL=postgresql://user:password@staging-db:5432/fitnes_saas
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d
# Staging istemcilerinin her origin'ini tam URL olarak ayri ayri listeleyin.
CORS_ORIGIN=https://staging-admin.example.com
DB_SYNC=false
# Demo talep kayitlarindaki PII bu sure dolunca fiziksel olarak silinir (30-3650 gun, varsayilan 365).
DEMO_LEAD_RETENTION_DAYS=365
EXPO_PUBLIC_E2E_MODE=1
