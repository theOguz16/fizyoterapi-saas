POSTGRES_DB=fitnes_saas
POSTGRES_USER=fizyoflow
POSTGRES_PASSWORD=replace-with-strong-password

JWT_SECRET=replace-with-long-random-secret
FIZYOFLOW_ADMIN_SECRET=replace-with-different-long-random-secret
JWT_EXPIRES_IN=7d
PRODUCTION_CORS_ORIGIN=https://app.fizyoflow.com,https://fizyoflow.com,https://www.fizyoflow.com
CORS_ORIGIN=https://app.fizyoflow.com,https://fizyoflow.com,https://www.fizyoflow.com
TRUST_PROXY=true
DB_SYNC=false

PUBLIC_WEB_BASE_URL=https://fizyoflow.com
WEB_BASE_URL=https://fizyoflow.com
ADMIN_WEB_URL=https://app.fizyoflow.com
WEB_URL=https://app.fizyoflow.com
MOBILE_DEEP_LINK_BASE=fizyoflow://
DETOUR_LINK_BASE_URL=

REVENUECAT_WEBHOOK_AUTH=Bearer replace-with-revenuecat-webhook-secret
REVENUECAT_ENTITLEMENT_ID=clinic_pro

FIZYOFLOW_BOOTSTRAP_ADMIN_EMAILS=

# Hostinger e-mail / SMTP (demo form notifications)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=iletisim@fizyoflow.com
SMTP_PASS=replace-with-mailbox-password
SMTP_FROM_EMAIL=iletisim@fizyoflow.com
SMTP_FROM_NAME=FizyoFlow
DEMO_LEAD_RECIPIENT_EMAIL=iletisim@fizyoflow.com

ENABLE_RISK_DAILY_BATCH=true
ENABLE_GROUP_CLASS_REMINDER_BATCH=true
GROUP_CLASS_REMINDER_HOURS=24,2
GROUP_CLASS_REMINDER_TOLERANCE_MINUTES=30

API_HOST_PORT=5511
WEB_HOST_PORT=3939
ADMIN_WEB_HOST_PORT=2929
AUTH_COOKIE_DOMAIN=.fizyoflow.com

# Only needed when using docker-compose.production.yml with the bundled Caddy proxy.
ACME_EMAIL=hello@fizyoflow.com
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-dns-edit-token

NEXT_PUBLIC_WEB_BASE_URL=https://fizyoflow.com
NEXT_PUBLIC_APP_URL=https://app.fizyoflow.com
NEXT_PUBLIC_API_BASE=https://api.fizyoflow.com/api
NEXT_PUBLIC_API_URL=https://api.fizyoflow.com/api
NEXT_PUBLIC_IOS_APP_URL=
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_ANDROID_APP_URL=
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
