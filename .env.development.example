NODE_ENV=development
PORT=5501
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitnes_saas
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
# Virgulle ayrilmis explicit origin listesi; wildcard ve subdomain kalibi desteklenmez.
CORS_ORIGIN=http://localhost:3000
DB_SYNC=false
# Demo talep kayitlarindaki PII bu sure dolunca fiziksel olarak silinir (30-3650 gun, varsayilan 365).
DEMO_LEAD_RETENTION_DAYS=365
EXPO_PUBLIC_E2E_MODE=1
