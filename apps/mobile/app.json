{
  "expo": {
    "name": "Clinerva",
    "slug": "clinerva-mobile",
    "scheme": "clinerva",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinerva.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Clinerva, QR görsellerini galeriye kaydetmek için fotoğraflara erişim izni ister.",
        "NSPhotoLibraryAddUsageDescription": "Clinerva, salon QR görsellerini galeriye kaydetmek için izin ister."
      }
    },
    "android": {
      "package": "com.clinerva.mobile",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-font",
      "react-native-purchases",
      [
        "expo-media-library",
        {
          "photosPermission": "Clinerva, QR görsellerini galeriye kaydetmek için fotoğraflara erişim izni ister.",
          "savePhotosPermission": "Clinerva, salon QR görsellerini galeriye kaydetmek için izin ister.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}