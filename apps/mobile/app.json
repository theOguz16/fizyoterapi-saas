{
  "expo": {
    "name": "Clinerva",
    "slug": "clinerva-mobile",
    "scheme": "clinerva",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinerva.mobile"
    },
    "android": {
      "package": "com.clinerva.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-font",
      "react-native-purchases"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
