{
  "name": "@fitnes-saas/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "../api/node_modules/.bin/vitest run -c vitest.config.ts",
    "test:watch": "../api/node_modules/.bin/vitest -c vitest.config.ts",
    "test:e2e": "if command -v maestro >/dev/null 2>&1; then maestro test tests/e2e/maestro; elif [ -x \"$HOME/.maestro/bin/maestro\" ]; then \"$HOME/.maestro/bin/maestro\" test tests/e2e/maestro; else echo \"Mobile e2e icin mobile.dev Maestro CLI gerekiyor. 'maestro test' komutu PATH'te olmali veya $HOME/.maestro/bin/maestro kurulu olmali.\" >&2; exit 1; fi",
    "release:env": "../api/node_modules/.bin/ts-node-dev --transpile-only --exit-child scripts/validate-release-env.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint app src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^3.10.0",
