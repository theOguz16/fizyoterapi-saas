NODE_ENV=production
PORT=5501
DATABASE_URL=postgresql://user:password@prod-db:5432/fitnes_saas
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d
# Production istemcilerinin her origin'ini tam URL olarak ayri ayri listeleyin; wildcard kullanmayin.
# CORS bir tarayici politikasidir, kimlik dogrulama siniri degildir. Klinik subdomain'leri yalniz /api/public icin credentials olmadan kabul edilir.
CORS_ORIGIN=https://admin.example.com
DB_SYNC=false
# Demo talep kayitlarindaki PII bu sure dolunca fiziksel olarak silinir (30-3650 gun, varsayilan 365).
DEMO_LEAD_RETENTION_DAYS=365
EXPO_PUBLIC_E2E_MODE=1
